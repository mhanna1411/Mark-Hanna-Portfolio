!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Mark Hanna | Aerospace Engineering</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Syne:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:#050A0F; --bg2:#090F17; --bg3:#0D1520; --surface:#0F1C2E;
      --border:rgba(0,180,255,0.12); --accent:#00B4FF; --accent2:#0066CC;
      --accent3:#00FFCC; --text:#E8F4FF; --text-dim:#7A9BB5;
      --text-muted:#3D5A73; --glow:0 0 30px rgba(0,180,255,0.15);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;overflow-x:hidden;cursor:none;}
    .cursor{position:fixed;top:0;left:0;width:12px;height:12px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:10000;mix-blend-mode:screen;}
    .cursor-ring{position:fixed;top:0;left:0;width:36px;height:36px;border:1px solid rgba(0,180,255,0.5);border-radius:50%;pointer-events:none;z-index:9999;transition:transform .15s ease;}
    #starfield{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;}
    .star{position:absolute;background:white;border-radius:50%;animation:twinkle var(--d,3s) ease-in-out infinite;opacity:0;}
    @keyframes twinkle{0%,100%{opacity:0}50%{opacity:var(--op,0.6)}}
    body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,180,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,180,255,0.025) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:1;}

    nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:20px 60px;background:rgba(5,10,15,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
    .nav-logo{font-family:'Orbitron',monospace;font-weight:700;font-size:1rem;letter-spacing:.2em;color:var(--accent);text-decoration:none;}
    .nav-logo span{color:var(--text-dim);}
    .nav-links{display:flex;gap:40px;list-style:none;}
    .nav-links a{font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.15em;color:var(--text-dim);text-decoration:none;text-transform:uppercase;transition:color .2s;position:relative;background:none;border:none;cursor:none;}
    .nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--accent);transition:width .3s;}
    .nav-links a:hover{color:var(--accent);}
    .nav-links a:hover::after{width:100%;}

    .page{display:none;position:relative;z-index:2;min-height:100vh;}
    .page.active{display:block;}

    /* HERO */
    #home-hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:120px 60px 80px;position:relative;overflow:hidden;}
    .hero-layout{display:flex;align-items:center;gap:80px;}
    .hero-content{flex:1;}

    /* Profile photo */
    .hero-photo-wrap{flex-shrink:0;width:260px;height:320px;position:relative;}
    .hero-photo-wrap::before{content:'';position:absolute;inset:-2px;background:linear-gradient(135deg,var(--accent),var(--accent3),var(--accent2));clip-path:polygon(0 0,calc(100% - 16px) 0,100% 16px,100% 100%,16px 100%,0 calc(100% - 16px));z-index:0;}
    .hero-photo-inner{position:absolute;inset:2px;background:var(--surface);clip-path:polygon(0 0,calc(100% - 14px) 0,100% 14px,100% 100%,14px 100%,0 calc(100% - 14px));overflow:hidden;z-index:1;display:flex;align-items:center;justify-content:center;}
    .hero-photo-inner img{width:100%;height:100%;object-fit:cover;display:block;}
    .photo-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;height:100%;gap:12px;color:var(--text-muted);}
    .photo-placeholder svg{opacity:.4;}
    .photo-placeholder span{font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text-muted);text-align:center;padding:0 16px;line-height:1.6;}
    .photo-upload-btn{font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);background:transparent;border:1px solid rgba(0,180,255,0.3);padding:8px 16px;cursor:pointer;transition:all .3s;margin-top:8px;}
    .photo-upload-btn:hover{background:rgba(0,180,255,0.08);border-color:var(--accent);}
    #photoInput{display:none;}
    .photo-corner{position:absolute;z-index:2;width:16px;height:16px;border-color:var(--accent3);border-style:solid;}
    .photo-corner.tl{top:-2px;left:-2px;border-width:2px 0 0 2px;}
    .photo-corner.tr{top:-2px;right:-2px;border-width:2px 2px 0 0;}
    .photo-corner.bl{bottom:-2px;left:-2px;border-width:0 0 2px 2px;}
    .photo-corner.br{bottom:-2px;right:-2px;border-width:0 2px 2px 0;}

    .hero-tag{font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.3em;color:var(--accent);text-transform:uppercase;margin-bottom:24px;opacity:0;animation:fadeUp .8s ease forwards .3s;}
    .hero-name{font-family:'Orbitron',monospace;font-size:clamp(3rem,7vw,6.5rem);font-weight:900;line-height:.95;letter-spacing:-.02em;margin-bottom:16px;opacity:0;animation:fadeUp .8s ease forwards .5s;}
    .hero-name .line1{display:block;color:var(--text);}
    .hero-name .line2{display:block;color:var(--accent);}
    .hero-subtitle{font-family:'Orbitron',monospace;font-size:clamp(.75rem,1.5vw,1rem);font-weight:400;letter-spacing:.25em;color:var(--text-dim);text-transform:uppercase;margin-bottom:40px;opacity:0;animation:fadeUp .8s ease forwards .7s;}
    .hero-bio{max-width:520px;font-size:1rem;line-height:1.75;color:var(--text-dim);margin-bottom:50px;opacity:0;animation:fadeUp .8s ease forwards .9s;}
    .hero-cta{display:flex;gap:20px;flex-wrap:wrap;opacity:0;animation:fadeUp .8s ease forwards 1.1s;}

    .btn-primary{font-family:'JetBrains Mono',monospace;font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;color:var(--bg);background:var(--accent);padding:14px 32px;border:none;cursor:none;transition:all .3s;clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));display:inline-block;}
    .btn-primary:hover{background:var(--accent3);transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,180,255,.3);}
    .btn-secondary{font-family:'JetBrains Mono',monospace;font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;color:var(--accent);background:transparent;padding:13px 32px;border:1px solid rgba(0,180,255,.4);cursor:none;transition:all .3s;clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,10px 100%,0 calc(100% - 10px));display:inline-block;}
    .btn-secondary:hover{border-color:var(--accent);background:rgba(0,180,255,.05);transform:translateY(-2px);}

    .scroll-indicator{position:absolute;bottom:40px;left:60px;display:flex;align-items:center;gap:16px;font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:.2em;color:var(--text-muted);text-transform:uppercase;opacity:0;animation:fadeUp .8s ease forwards 1.5s;}
    .scroll-line{width:40px;height:1px;background:linear-gradient(to right,transparent,var(--text-muted));}

    section{position:relative;z-index:2;}
    .section-wrapper{max-width:1200px;margin:0 auto;padding:100px 60px;}
    .section-label{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.3em;color:var(--accent);text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:16px;}
    .section-label::before{content:'';display:inline-block;width:30px;height:1px;background:var(--accent);}
    .section-title{font-family:'Orbitron',monospace;font-size:clamp(2rem,4vw,3.2rem);font-weight:700;line-height:1.1;margin-bottom:60px;}

    /* ABOUT */
    .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;}
    .about-text p{font-size:1rem;line-height:1.8;color:var(--text-dim);margin-bottom:20px;}
    .about-stats{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:40px;}
    .stat-box{background:var(--surface);border:1px solid var(--border);padding:24px;position:relative;overflow:hidden;}
    .stat-box::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--accent);}
    .stat-num{font-family:'Orbitron',monospace;font-size:2rem;font-weight:700;color:var(--accent);display:block;}
    .stat-label{font-size:.8rem;color:var(--text-muted);letter-spacing:.05em;margin-top:4px;}
    .skills-panel{background:var(--surface);border:1px solid var(--border);padding:40px;}
    .skills-panel h3{font-family:'Orbitron',monospace;font-size:.9rem;letter-spacing:.15em;color:var(--text-dim);text-transform:uppercase;margin-bottom:28px;}
    .skill-item{margin-bottom:20px;}
    .skill-header{display:flex;justify-content:space-between;margin-bottom:8px;}
    .skill-name{font-family:'JetBrains Mono',monospace;font-size:.8rem;color:var(--text);}
    .skill-pct{font-family:'JetBrains Mono',monospace;font-size:.8rem;color:var(--accent);}
    .skill-bar{height:3px;background:rgba(0,180,255,.1);position:relative;overflow:hidden;}
    .skill-fill{height:100%;background:linear-gradient(to right,var(--accent2),var(--accent));transform-origin:left;animation:growBar 1.5s cubic-bezier(.25,1,.5,1) forwards;transform:scaleX(0);}
    @keyframes growBar{to{transform:scaleX(1);}}

    /* EDUCATION */
    .edu-card{background:var(--surface);border:1px solid var(--border);padding:40px;position:relative;overflow:hidden;transition:border-color .3s,box-shadow .3s;}
    .edu-card:hover{border-color:rgba(0,180,255,.3);box-shadow:var(--glow);}
    .edu-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--accent),transparent);}
    .edu-degree{font-family:'Orbitron',monospace;font-size:1.1rem;font-weight:600;color:var(--text);margin-bottom:8px;}
    .edu-school{font-size:1rem;color:var(--accent);margin-bottom:6px;}
    .edu-meta{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--text-muted);letter-spacing:.1em;margin-bottom:24px;}
    .coursework-title{font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:.2em;color:var(--accent);text-transform:uppercase;margin-bottom:16px;}
    .course-tags{display:flex;flex-wrap:wrap;gap:8px;}
    .course-tag{font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--text-dim);background:rgba(0,180,255,.05);border:1px solid var(--border);padding:6px 12px;letter-spacing:.05em;}

    /* TIMELINE */
    .timeline{position:relative;padding-left:30px;}
    .timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,var(--accent),transparent);}
    .timeline-item{position:relative;margin-bottom:60px;padding-left:40px;}
    .timeline-dot{position:absolute;left:-34px;top:6px;width:8px;height:8px;background:var(--accent);border-radius:50%;box-shadow:0 0 12px var(--accent);}
    .timeline-date{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.15em;color:var(--accent);text-transform:uppercase;margin-bottom:8px;}
    .timeline-role{font-family:'Orbitron',monospace;font-size:1.05rem;font-weight:600;color:var(--text);margin-bottom:4px;}
    .timeline-org{font-size:.9rem;color:var(--text-dim);margin-bottom:16px;}
    .timeline-details{list-style:none;}
    .timeline-details li{font-size:.88rem;color:var(--text-muted);line-height:1.7;margin-bottom:8px;padding-left:18px;position:relative;}
    .timeline-details li::before{content:'›';position:absolute;left:0;color:var(--accent);font-size:1rem;}

    /* PROJECTS LIST */
    .projects-list{display:flex;flex-direction:column;gap:2px;}
    .project-row{background:var(--surface);border:1px solid var(--border);padding:32px 40px;display:flex;align-items:center;justify-content:space-between;cursor:none;transition:all .3s;position:relative;overflow:hidden;}
    .project-row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent);transform:scaleY(0);transform-origin:top;transition:transform .3s ease;}
    .project-row:hover{border-color:rgba(0,180,255,.3);background:rgba(0,180,255,.03);transform:translateX(4px);box-shadow:var(--glow);}
    .project-row:hover::before{transform:scaleY(1);}
    .project-row-left{display:flex;align-items:center;gap:32px;}
    .project-row-num{font-family:'Orbitron',monospace;font-size:1.4rem;font-weight:900;color:rgba(0,180,255,.2);min-width:40px;}
    .project-row-title{font-family:'Orbitron',monospace;font-size:1rem;font-weight:600;color:var(--text);margin-bottom:6px;letter-spacing:.04em;}
    .project-row-meta{font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--accent);letter-spacing:.12em;text-transform:uppercase;}
    .project-row-tags{display:flex;gap:8px;flex-wrap:wrap;}
    .project-row-tag{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--text-muted);background:rgba(0,180,255,.05);border:1px solid var(--border);padding:4px 10px;}
    .project-row-arrow{font-size:1.4rem;color:var(--accent);transition:transform .3s;font-family:'JetBrains Mono',monospace;opacity:.5;}
    .project-row:hover .project-row-arrow{transform:translateX(6px);opacity:1;}

    /* CONTACT */
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;}
    .contact-intro p{font-size:1rem;line-height:1.8;color:var(--text-dim);margin-bottom:40px;}
    .contact-links{display:flex;flex-direction:column;gap:16px;}
    .contact-link{display:flex;align-items:center;gap:20px;text-decoration:none;padding:20px 24px;background:var(--surface);border:1px solid var(--border);transition:all .3s;position:relative;overflow:hidden;}
    .contact-link:hover{border-color:rgba(0,180,255,.3);background:rgba(0,180,255,.03);}
    .contact-link::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--accent);}
    .contact-icon{font-size:1.2rem;color:var(--accent);min-width:24px;}
    .contact-type{font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:.2em;color:var(--text-muted);text-transform:uppercase;display:block;margin-bottom:4px;}
    .contact-val{font-size:.9rem;color:var(--text);}
    .contact-form{display:flex;flex-direction:column;gap:16px;}
    .form-group{display:flex;flex-direction:column;gap:8px;}
    .form-label{font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:.2em;color:var(--text-muted);text-transform:uppercase;}
    .form-input,.form-textarea{background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:'Syne',sans-serif;font-size:.9rem;padding:14px 18px;outline:none;transition:border-color .3s;resize:none;}
    .form-input:focus,.form-textarea:focus{border-color:rgba(0,180,255,.4);}
    .form-textarea{min-height:120px;}

    footer{position:relative;z-index:2;border-top:1px solid var(--border);padding:30px 60px;display:flex;align-items:center;justify-content:space-between;background:var(--bg);}
    .footer-logo{font-family:'Orbitron',monospace;font-size:.8rem;font-weight:700;letter-spacing:.2em;color:var(--accent);}
    .footer-copy{font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:.1em;color:var(--text-muted);}

    /* PROJECT DETAIL */
    #page-project{padding-top:100px;}
    .project-detail-wrapper{max-width:1100px;margin:0 auto;padding:60px 60px 100px;}
    .back-btn{display:inline-flex;align-items:center;gap:10px;font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text-dim);text-decoration:none;cursor:none;margin-bottom:48px;transition:color .2s;border:none;background:none;padding:0;}
    .back-btn:hover{color:var(--accent);}
    .back-btn svg{transition:transform .2s;}
    .back-btn:hover svg{transform:translateX(-4px);}
    .detail-num{font-family:'Orbitron',monospace;font-size:5rem;font-weight:900;color:rgba(0,180,255,.07);line-height:1;margin-bottom:-20px;}
    .detail-title{font-family:'Orbitron',monospace;font-size:clamp(1.6rem,3.5vw,2.8rem);font-weight:700;color:var(--text);margin-bottom:12px;line-height:1.15;}
    .detail-org{font-family:'JetBrains Mono',monospace;font-size:.8rem;letter-spacing:.2em;color:var(--accent);text-transform:uppercase;margin-bottom:24px;}
    .detail-tags{display:flex;flex-wrap:wrap;gap:8px;}
    .detail-tag{font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--accent3);background:rgba(0,255,204,.05);border:1px solid rgba(0,255,204,.15);padding:5px 12px;}
    .detail-divider{height:1px;background:linear-gradient(to right,var(--accent),transparent);margin:48px 0;}
    .detail-section-title{font-family:'Orbitron',monospace;font-size:.85rem;letter-spacing:.2em;color:var(--text-dim);text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:12px;}
    .detail-section-title::before{content:'//';color:var(--accent);}
    .detail-contributions{list-style:none;display:flex;flex-direction:column;gap:16px;margin-bottom:60px;}
    .detail-contributions li{font-size:.95rem;line-height:1.8;color:var(--text-dim);padding:20px 24px;background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);}

    /* GALLERY */
    .photo-gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;}
    .gallery-slot{aspect-ratio:4/3;background:var(--surface);border:1px solid var(--border);position:relative;overflow:hidden;transition:border-color .3s;}
    .gallery-slot:hover{border-color:rgba(0,180,255,.3);}
    .gallery-slot img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s ease;}
    .gallery-slot:hover img{transform:scale(1.04);}
    .gallery-placeholder{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:var(--text-muted);}
    .gallery-placeholder svg{opacity:.3;}
    .gallery-placeholder span{font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;opacity:.5;}
    .gallery-upload-label{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:background .2s;}
    .gallery-upload-label:hover{background:rgba(0,180,255,.06);}
    .gallery-upload-input{display:none;}
    .gallery-add-text{font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);opacity:0;transition:opacity .2s;position:absolute;bottom:14px;}
    .gallery-slot:hover .gallery-add-text{opacity:1;}

    @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
    .reveal{opacity:0;transform:translateY(40px);transition:opacity .7s ease,transform .7s ease;}
    .reveal.visible{opacity:1;transform:none;}

    @media(max-width:900px){
      nav{padding:16px 24px;} .nav-links{gap:16px;}
      #home-hero{padding:120px 24px 80px;}
      .hero-layout{flex-direction:column-reverse;gap:40px;}
      .hero-photo-wrap{width:200px;height:240px;margin:0 auto;}
      .section-wrapper{padding:80px 24px;}
      .about-grid,.contact-grid{grid-template-columns:1fr;gap:40px;}
      .photo-gallery{grid-template-columns:1fr 1fr;}
      .project-detail-wrapper{padding:40px 24px 80px;}
      .project-row{flex-direction:column;align-items:flex-start;gap:16px;}
      footer{flex-direction:column;gap:12px;text-align:center;padding:24px;}
    }
  </style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>
<div id="starfield"></div>

<nav>
  <a href="#" class="nav-logo" onclick="goHome();return false;">MH<span>.AE</span></a>
  <ul class="nav-links">
    <li><a href="#" onclick="goHome();navScroll('#about');return false;">About</a></li>
    <li><a href="#" onclick="goHome();navScroll('#education');return false;">Education</a></li>
    <li><a href="#" onclick="goHome();navScroll('#experience');return false;">Experience</a></li>
    <li><a href="#" onclick="goHome();navScroll('#projects');return false;">Projects</a></li>
    <li><a href="#" onclick="goHome();navScroll('#contact');return false;">Contact</a></li>
  </ul>
</nav>

<!-- ══════════ HOME PAGE ══════════ -->
<div id="page-home" class="page active">

  <div id="home-hero">
    <div class="hero-layout">
      <div class="hero-content">
        <div class="hero-tag">// Aerospace Engineering Student · NCSU</div>
        <h1 class="hero-name">
          <span class="line1">MARK</span>
          <span class="line2">HANNA</span>
        </h1>
        <p class="hero-subtitle">Aerodynamics · Rocketry · Structural Design</p>
        <p class="hero-bio">Aerospace Engineering student with a strong foundation in aerodynamics, solid mechanics, and rocketry. Experienced in high-impact projects including a NASA Student Launch competition entry, focusing on structural assembly and composite fabrication.</p>
        <div class="hero-cta">
          <button class="btn-primary" onclick="navScroll('#projects')">View Projects</button>
          <button class="btn-secondary" onclick="navScroll('#contact')">Get In Touch</button>
        </div>
      </div>

      <!-- PROFILE PHOTO -->
      <div class="hero-photo-wrap">
        <div class="hero-photo-inner" id="photoContainer">
          <div class="photo-placeholder" id="photoPlaceholder" style="display:none;">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="18" r="9" stroke="#3D5A73" stroke-width="1.5"/>
              <path d="M6 42c0-9.94 8.06-18 18-18s18 8.06 18 18" stroke="#3D5A73" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>Add your<br/>profile photo</span>
